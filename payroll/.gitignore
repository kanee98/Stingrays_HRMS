# Environment files
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env*.example
frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env*.example

# Dependencies
backend/node_modules/
frontend/node_modules/

# Backend build output and caches
backend/dist/
backend/build/
backend/coverage/
backend/.nyc_output/
backend/.cache/
backend/.eslintcache
backend/*.tsbuildinfo

# Frontend build output and caches
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.cache/
frontend/.turbo/
frontend/.eslintcache
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Copied shared sources for local builds
frontend/shared/

# Deployment artifacts
frontend/.vercel/

# Logs
backend/*.log
frontend/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor noise
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
