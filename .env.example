# Copy this file to .env before starting the DB/app Compose stacks.

# Compose and host ports
COMPOSE_PROJECT_NAME=stingrays_hrms
APP_FRONTEND_PORT=3000
APP_BACKEND_PORT=4000
MSSQL_PORT=1433

# Public application URL and frontend defaults
# Set this to the real public app origin in hosted environments.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CLIENT_KEY=stingrays

# Backend runtime and CORS
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_PORT=4000

# SQL Server
MSSQL_PID=Developer
DB_HOST=mssql
DB_PORT=1433
DB_NAME=StingraysHRMS
DB_USER=sa
DB_PASSWORD="Kanishka#9810"

# Auth secrets
PASETO_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_PASETO_SECRET=replace-with-a-second-long-random-secret

# Seed users created by the DB init container
AUTH_SEED_EMAIL=admin@stingrays.com
AUTH_SEED_PASSWORD=Admin@123
AUTH_SEED_NAME=Platform Administrator
SUPER_ADMIN_SEED_EMAIL=superadmin@fusionlabz.lk
SUPER_ADMIN_SEED_PASSWORD=SuperAdmin@123
SUPER_ADMIN_SEED_NAME=FusionLabz Platform Super Admin
SUPER_ADMIN_DEFAULT_CLIENT_KEY=stingrays
SUPER_ADMIN_DEFAULT_CLIENT_NAME=Stingrays
