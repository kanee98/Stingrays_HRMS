# Disable Compose Bake on Docker Desktop when multi-image builds hit BuildKit snapshot/export errors.
# COMPOSE_BAKE=false

# Copy to .env and adjust. .env is git-ignored so server config is not overwritten on git push.
#
# --- Local defaults (no .env required):
# Portal:        http://localhost:3000
# Employee UI:   http://localhost:3001
# HRMS UI:       http://localhost:3002
# Payroll UI:    http://localhost:3010
# Super Admin:   http://localhost:3020
# Employee API:  http://localhost:4000
# Auth service:  http://localhost:4001
# Payroll API:   http://localhost:4010
# Super Admin API: http://localhost:4020
#
# Set the default client key that frontends should request from the Super Admin API:
# NEXT_PUBLIC_DEFAULT_CLIENT_KEY=stingrays
#
# --- Server (IP only): set your server IP so frontends point to the right URLs:
# PUBLIC_HOST=107.175.85.91
#
# --- Server (subdomain + reverse proxy, see PROXY.md):
# AUTH_SERVICE_INTERNAL_URL=http://auth-service:4000
# NEXT_PUBLIC_AUTH_SERVICE_URL=https://auth.stingraysglobal.com
# NEXT_PUBLIC_PORTAL_URL=https://portal.stingraysglobal.com
# NEXT_PUBLIC_HRMS_URL=https://hrms.stingraysglobal.com
# NEXT_PUBLIC_EMPLOYEE_UI_URL=https://employee.stingraysglobal.com
# NEXT_PUBLIC_EMPLOYEE_API_URL=https://employee-api.stingraysglobal.com
# NEXT_PUBLIC_PAYROLL_URL=https://payroll.stingraysglobal.com
# NEXT_PUBLIC_PAYROLL_API_URL=https://payroll-api.stingraysglobal.com
# NEXT_PUBLIC_SUPER_ADMIN_URL=https://super-admin.stingraysglobal.com
# NEXT_PUBLIC_SUPER_ADMIN_API_URL=https://super-admin-api.stingraysglobal.com
# NEXT_PUBLIC_DEFAULT_CLIENT_KEY=stingrays
