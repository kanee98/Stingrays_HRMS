{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["./src/shared/*"],
      "@portal/*": ["./src/modules/portal/*"],
      "@hrms/*": ["./src/modules/hrms/*"],
      "@employee/*": ["./src/modules/employee/*"],
      "@payroll/*": ["./src/modules/payroll/*"],
      "@admin/*": ["./src/modules/admin/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/modules/**/app/api/**/*.ts",
    "src/modules/**/app/api/**/*.tsx"
  ]
}
